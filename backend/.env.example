# Variáveis de ambiente - copie este arquivo para .env e preencha com seus dados reais
# NUNCA comite o arquivo .env com tokens reais

# Porta onde o servidor irá escutar
PORT=8080

# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
# Exemplo: openssl rand -base64 32
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria

# URL base do servidor MK Solutions ERP
# Exemplo: http://SEU_IP_MK:8080
MK_API_URL=http://SEU_IP_OU_HOST_MK:8080

# Token de autenticação da API MK Solutions
# Obtido no painel de configurações do MK Solutions
MK_AUTH_TOKEN=seu-token-mk-aqui

# Senha de autenticação da API MK Solutions
MK_AUTH_PASSWORD=sua-senha-mk-aqui
